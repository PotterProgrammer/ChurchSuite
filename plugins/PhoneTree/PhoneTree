	##
	##  On startup, schedule test every minute to see if Messenger
	##  task needs to be started. (This is for
	##  instances where a shutdown happened while
	##  messages were being sent.)
	##
	Mojo::IOLoop->recurring( 60 => sub($bob)
		{
			if ( messagesArePending())
			{
				##
				##  Is a messenger running?
				##
				if (( defined( $messenger) && ! $messenger->poll()) ||
					( !defined( $messenger)))
				{
					startMessenger();
				}
			}
		});

