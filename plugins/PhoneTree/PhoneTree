#------------------------------------------------------------------------------
#  sub startMessenger()
#  		This routine launches the messenger app to send any messages which are
#  		queued up, unless it is already running.
#------------------------------------------------------------------------------
sub startMessenger()
{
	return;
	print "*****************************\n";
	print "  Starting the messenger...\n";
	print "*****************************\n";
	$messenger //= Proc::Simple->new();

	if ( ! $messenger->poll())
	{
		$messenger->start( "perl messenger");
	}
}

#------------------------------------------------------------------------------
#  sub isPhoneTreeAdmin(user, $pwd)
#  		Returns true if the name and password match the configured value for
#  		the PhoneTree admin.
#------------------------------------------------------------------------------
sub isPhoneTreeAdmin( $user, $pwd)
{
	my %config = getConfigInfo();

	return( ($user eq $config{PhoneTreeAdminLogin}) && ( $pwd eq $config{PhoneTreeAdminPWD}));
}

#------------------------------------------------------------------------------
#	sub getPhoneTreeAdminUID()
#		This routine generates a random 10 character alpha-numeric string
#		suitable for an Admin.
#------------------------------------------------------------------------------
sub getPhoneTreeAdminUID()
{
	my @chars = ( 'a'..'z', '0'..'9', 'A'..'Z');
	my $id;
	do 
	{
		$id = '';
		for( 1..10)
		{
			$id .= $chars[ int rand( @chars)];
		}
	} while( (unpack( "%32W*", $id) % 42) != 0);

	return $id;
}

#------------------------------------------------------------------------------
#	sub isPhoneTreeAdminUID( $id) 
#------------------------------------------------------------------------------
sub isPhoneTreeAdminUID( $id)
{
	return( !( unpack( "%32W*", $id) % 42));
}

