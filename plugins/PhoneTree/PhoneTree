	#------------------------------------------------------------------------------
	#	websocket '/getMessageList'
	#		This method is called to get a list of members that are in the message
	#		queue.  It may optionally receive a type of 'all' to list all members.
	#		If the type is unspecified or not 'all', it defaults to a list of 
	#		all messages that have not yet been sent.  It returns a reference
	#		to an array of hashrefs.  The hashrefs reference the fields:
	#			(rowid, fromWho, subject, message, sendOn, status, retry)
	#------------------------------------------------------------------------------
	websocket '/getMessageList' => sub
	{
		my $self = shift;

		##
		##  Get a list of pending members
		##
		$self->on( message => sub
					{
						my ($self, $type) = @_;

						my $list = ( defined($type) && ($type eq 'all')) ? allMessages() : allPendingMessages();
						$self->send( {json => $list});
					}
				 );
	};

	#------------------------------------------------------------------------------
	#	websocket '/messagesVary'
	#		This call checks to see if the messages queued to be sent, that are
	#		identified by their rowids in the comma-separated list of numbers,
	#		have varying message content.  A non-zero value is returned if the
	#		message texts differ.
	#------------------------------------------------------------------------------
	websocket '/messagesVary' => sub
	{
		my $self = shift;

		##
		##  Get a list of pending members
		##
		$self->on( message => sub
					{
						my ($self, $list) = @_;

						my @rowIds = split( ",", $list);
						my $result = messagesVary( \@rowIds);
						$self->send( {json => $result });
					}
				 );
	};
	
	#------------------------------------------------------------------------------
	#	websocket '/backup'
	#		This call stores the existing config and database in a tar file,
	#		encrypts it, and then makes it available for download.
	#------------------------------------------------------------------------------
	websocket '/backup' => sub
	{
		my $ws = shift;

		$ws->on (text => sub
			{
				$ws->inactivity_timeout(300);
				my ($ws, $message) = @_;

				print "Got a '$message' request\n";
				if ( $message =~ m/Backup/)
				{
					my $backupFilename = backupData( $backupPassphrase);
					$ws->send( $backupFilename);
				}
				else
				{
					$ws->send( "What??!");
				}
			}
			);
	};



