	#------------------------------------------------------------------------------
	#	post '/sendMessage' 
	#------------------------------------------------------------------------------
	post '/sendMessage' => sub
	{
		my ( $self) = @_;

		my $toList = $self->every_param( 'individuals');
		my $from =  $self->param( 'from');
		my $message = $self->param( 'theMessage');
		my $subject = $self->param( 'subject');
		my $whenToSend = $self->param( 'whenToSend');
		my $messageIds = $self->param( 'messageIds');   #  Ids of messages to replace, may be undefined.

		##
		##  Is this a change to a scheduled message?
		##
		if ( defined( $messageIds))
		{
			print "\n\nMessage IDS are: $messageIds\n\n";
			openDB();
			startTransaction();

			my @messagesToRemove = split( ',', $messageIds);
			deleteSelectedMessages( \@messagesToRemove);
		}

		##
		##  Queue up the list of messages to send
		##
		foreach my $id (@$toList)
		{
			my $info = readContactInfo( $id);
			my $name = $info->{firstname} . ' ' . $info->{lastname};
			print "Sending message to $name ($id) from $from with a subject of \"$subject\" and a message of \"$message\".\n";
			storeMessage( $id, $from, $subject, $message, $whenToSend);
		}

		##
		##  Commit transaction, if rescheduling messages
		##
		if ( defined( $messageIds))
		{
			commitTransaction();
			closeDB();
		}
		

		##
		##  Make sure the messenger is sending queued messages
		##
		startMessenger();

		if ( defined( $whenToSend))
		{
			$self->stash( title => 'Messages Queued', textMessage=>"Messages will be sent on $whenToSend", showFor => 2000);
		}
		else
		{
			$self->stash( title => 'Messages Sending', textMessage=>"Messages are being sent", showFor => 2000);
		}

		$self->render( "index");
	};
	
	
	#------------------------------------------------------------------------------
	#	post '/restore'
	#		This call carries out the actual restore
	#------------------------------------------------------------------------------
	post '/restore' => sub
	{
		my $self = shift;
	 
		# Check file size
		if ($self->req->is_limit_exceeded)
		{
			return $self->render(text => 'File is too big.', status => 200);
		}
	 
		# Process uploaded file
		my $filename = $self->param('filename');

		my %response = restoreBackup( $filename, $backupPassphrase);

		$self->stash( textMessage => $response{textMessage}, backupFile=> $response{backupFile}, title=> $response{title}, showFor => $response{showFor});
		
		if ( !defined( $response{backupFile}))
		{
			print "Rendering index...\n";
			$self->render( 'index');
		}
		else
		{
			$self->render( 'restoreBackup');
		}
	};
	
