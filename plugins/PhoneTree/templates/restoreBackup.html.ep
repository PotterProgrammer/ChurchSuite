<!DOCTYPE html>

<html>
<head>
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
	<link rel="stylesheet" href="/phonetree/site.css">
</head>

<script src="/common/loadNav.js"> </script>
<script src="/common/Dialog.js"></script>

<script>

	function verifyConfigOverwrite()
	{
		let message = 'The backup file contains configuration settings for email or texting that are different than the current settings.<br>Do you wish to use the settings from the backup file?'

		Dialog.Confirm( {text: message, title: "Caution:"}).then( (answer) =>
			{
				if ( answer)
				{
					fetch( '/phonetree/restoreCommon',
							{
								method: "POST",
								body: JSON.stringify( { 'backupName': '<%= $backupFile %>'}),
								headers: { "Content-type": "application/json"}
							}
						  )
					.then( response => 
							{
								window.location.href = 'index';
							});
				}
				else
				{
					fetch( '/phonetree/releaseBackupData',
							{
								method: "POST",
								body: JSON.stringify( { 'backupName': '<%= $backupFile %>'}),
								headers: { "Content-type": "application/json"}
							}
						  )
					.then( response => 
							{
								window.location.href = 'index';
							});
				}
			});
	}


% if ( defined( stash( 'backupFile')))
% {	
	window.addEventListener( "pageshow", function () {verifyConfigOverwrite();} );
% }

</script>


<body>
	<div id="navbar">
	</div>

	<h1>Restore from Backup</h1>

	<div id="confirmRestore">
		<p>This process will restore the PhoneTree environment (including photos, information, administrtors and settings) to the state that it was in when the backup file was created.</p>
		<p>Note that this will erase <b><u>all</u></b> currently entered information, replacing it with the contents of the backup file!</p>
		<p>Are you sure you wish to continue?</p>
		<br>
		<div class ="buttonRow twoButtons">
			<input type="submit" name="submit" id="submitbtn" class="submitbtn" value="Yes" onclick="document.getElementById('filename').click();">
			<input type="submit" formnovalidate name="submit" id="resetbtn" class="resetbtn" value="No" onclick="window.location='/phonetree/index'">
		</div>
		<form action = "/phonetree/restore" method="post" enctype="multipart/form-data" hidden>
			<input id="filename" type="file" name="filename" onchange="document.getElementById('sendBackup').click();" hidden/>
			<button id="sendBackup" type="submit" hidden/>
		</form>
	</div>
</body>

</html>

