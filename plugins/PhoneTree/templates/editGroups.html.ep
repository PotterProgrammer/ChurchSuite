//-->
}

//==============================================================================
//  function setGroupMembers()
//==============================================================================
function setGroupMembers()
{
	//
	//  First clear the list
	//
	unSelectAllMembers();

	//
	//  Next, get the current members of the named group
	//
	let groupName = document.getElementById("groups").value;
	readGroupMemberList( groupName)
		.then( (list) =>
			{
				let select = document.getElementById( 'groupMembers');

				list.forEach( (row) =>
					{
						let name = row.memberName;
						let id = row.id;
						let isGroup = (row.isGroup != 1) ? 'member' : 'group';
						let options = document.querySelectorAll( `[value="${id}"][type="${isGroup}"]`);
						for( let option of options)
						{
							option.selected = true;
						}
					});

			});

}

//==============================================================================
//  function refreshGroupMemberList()
//  	This function refreshes the list of group member names.
//==============================================================================
function refreshGroupMemberList()
{
	let select = document.getElementById( 'groupMembers');

	//
	//  First clear the list
	//
	while( select.options.length > 0)
	{
		select.remove(0);
	}

	//
	//  Next, get the current group list
	//
	readGroupList()
		.then( (list) =>
			{
				let select = document.getElementById( 'groupMembers');

				list.forEach( (row) =>
					{
						let option = new Option( row[0], row[0]);
						option.className = "multiSel";
						option.setAttribute( "type", "group");
						select.add( option);
					});

			})
		.then( () =>
			{
				readContactList()
					.then(( list) =>
						{
							let select = document.getElementById( 'groupMembers');

							list.forEach( (row) =>
								{
									let option = new Option( row.firstname + " " + row.lastname, row.rowid);
									option.className = "multiSel";
									option.setAttribute( "type", "member");
									select.add( option);
								});

							multiSelectWithoutCtrl('multiSel');
						});
			});


}


//
//  Set the modified event handler for the member list once the page has loaded
//
window.addEventListener( "load", function ()
	{
		refreshGroupList();
		refreshGroupMemberList();
	});
</script>


<body>
	<div id="navbar">
	</div>

<h1>Edit Groups</h1>

<p id="instructions">
	Enter the name of the new group. Or click on the down arrow, select the
	name of an existing group from the box on the left, and click the <b>Show Members</b> button.
	Then, select the names of those who are a part of that group from the box on the right.
	Press the <b>Save Group</b> button when all group members are selected.
	To remove a group, select the group name and press <b>Delete Group</b>.
</p>

<div id="screen" style="justify-content:center">
	<div class="groupColumnItem">
		<div class="groupRowItem">
			<div class="flexCentered">
				<span class="withDropdown">
				<label for="groups">Group Name:</label>
				<input name="groups" id="groups" list="groupName" tabindex="1" placeholder="Enter group name..." onchange="setGroupMembers()">
				<datalist id="groupName">
					<option value="Choir">Choir</option>
					<option value="Trustees">Trustees</option>
					<option value="SPR">SPR</option>
				</datalist>
				</span>
				<button onClick="setGroupMembers()" id="memberButton">Show Members</button>
			</div>
		</div>
		<div class="groupRowItem">
			<div id="buttons">
				<button type="button" onclick="saveGroup()">Save Group</button -->
				<button type="button" onclick="removeGroup()">Delete Group</button>
			</div>
		</div>
	</div>
	
	<div class="groupColumnItem">
		<div class="groupRowItem showCheckBoxes">
			<select name="groupMembers" class="groupMembers" id="groupMembers" size="11" multiple>
				<option value="Choir" class="multiSel" type="group">Choir</option>
				<option value="Bob 41" class="multiSel" type="member">Bob</option>
				<option value="Gus 41" class="multiSel" type="member">Gus</option>
				<option value="Sam 41" class="multiSel" type="member">Sam</option>
				<option value="Joe 41" class="multiSel" type="member">Joe</option>
				<option value="Will 41" class="multiSel" type="member">William A. Stanley</option>
			</select>
		</div>
		<div class="groupRowItem">
			<div class="selectAllButtons">
			<button onClick="selectAllMembers()">Select All</button>
			<button onClick="unSelectAllMembers()">Select None</button>
			</div>
		</div>
	</div>
</div>
</body>
</html>

