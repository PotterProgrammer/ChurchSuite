<!DOCTYPE html>
<html>

<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <link rel="stylesheet" href="/phonetree/site.css">
</head>

<script src="/common/Dialog.js"></script>
<script src="/common/loadNav.js"></script>
<script src="/common/PhoneTree.js"></script>

<script>

let contactList = new Map();
let selectedOptions = new Array();

//==============================================================================
//  function refreshGroupList()
//==============================================================================
function refreshGroupList()
{
	redrawGroupList( "groups", () => {multiSelectWithoutCtrl( 'multiSel')}, groupSelected);
	let groupList = document.getElementById( "groups");
	groupList.addEventListener( "change", (event) => {handleGroupChange(event)});
}

//==============================================================================
//  function refreshContactsList()
//  	This function refreshes the list of contact names.
//==============================================================================
function refreshContactsList()
{
	let select = document.getElementById( 'individuals');

	//
	//  First clear the list
	//
	while( select.options.length > 0)
	{
		select.remove(0);
	}

	readContactList()
		.then(( list) =>
			{
				let select = document.getElementById( 'individuals');

				list.forEach( (row) =>
					{
						let option = new Option( row.firstname + " " + row.lastname, row.rowid);
						option.className = "multiSel";
						option.setAttribute( "type", "member");
						option.addEventListener( 'click', () => {clickedContact( option)});
						select.add( option);
					});

				multiSelectWithoutCtrl('multiSel');
			});
}

//==============================================================================
//  function clickedContact( item)
//		This function is called whenever a contact is clicked.  It either sets
//		the entry in contactList to 1 (if it is not currently set) or removes
//		it from the list.
//==============================================================================
function clickedContact( item)
{
	if ( contactList.has( Number(item.value)))
	{
		contactList.delete( item.value);
	}
	else
	{
		contactList.set( Number(item.value), 1);
	}
}

//==============================================================================
//  function clearContacts()
//		This function clears the checkboxes in all entries in the contact list,
//		and clears all entries in the groups list.
//==============================================================================
function clearContacts()
{
	unSelectAllItems( 'individuals');
	unSelectAllItems( 'groups');
	selectedOptions.length = 0;
	contactList.clear();
}

//==============================================================================
//  function selectAllContacts()
//		This function sets the checkboxes in all entries in the contact list,
//		and clears all entries in the groups list.
//==============================================================================
function selectAllContacts()
{
	unSelectAllItems( 'groups');
	selectedOptions.length = 0;
	let list = document.getElementById( 'individuals');
	for( let option of list.options)
	{
		option.selected = true;
		contactList.set( Number(option.value), 1);
	}
}

//==============================================================================
//  function groupSelected( item)
//		This function is called whenever a group is selected (checked or unchecked).
//		This usually fires only on desktop browsers.
//==============================================================================
function groupSelected( item)
{
	//
	//  Get a list of members in this group
	//
	if ( item.selected)
	{
		//
		//  Select each name in the list (and increment
		//  occurrence count in the memberList)
		//
		updateContactList( item.value, 1);
	}
	else
	{
		//
		//  Unselect each name in the list (and increment
		//  occurrence count in the memberList)
		//
		updateContactList( item.value, -1);
	}
}


//==============================================================================
//  function handleGroupChange( theEvent)
//		This function is called when the "Groups" select object changes.  (This
//		usually happens only on a mobile device.)
//==============================================================================
function handleGroupChange( theEvent)
{
	let select = theEvent.target;

	//
	//  Get a list of all selected options
	//
	newSelectedOptions = Array.from(select.selectedOptions);

	//
	//  Find the option that is different between the new list and the old
	//
	const addedOption = newSelectedOptions.filter( x => !selectedOptions.includes(x));
	const removedOption = selectedOptions.filter( x => !newSelectedOptions.includes(x));

	if ( addedOption.length > 0)
	{
		//
		//  Select each name in the list (and increment
		//  occurrence count in the memberList)
		//
		updateContactList( addedOption[0].value, 1);
	}
	else
	{
		//
		//  Unselect each name in the list (and increment
		//  occurrence count in the memberList)
		//
		updateContactList( removedOption[0].value, -1);
	}
	selectedOptions = newSelectedOptions;
}

//==============================================================================
//  function updateContactList( groupName, adjustByAmount)
//		This function is called whenever a group is selected or unselected.  It
//		returns a Promise.  It retrieves the members of the group (which may
//		include other groups) and then iterates through the list.  It adjusts
//		the value for the member in the contactList by the adjustByAmount.  If
//		the value is positive, it selects the corresponding entry in the list
//		of individuals.  If the value is zero, then the corresponding name is
//		unselected and the entry is removed from the contactList map.
//==============================================================================
function updateContactList( groupName, adjustByAmount)
{
	return new Promise((resolve, reject) =>
		{
			readGroupMemberList( groupName)
				.then( (list) =>
					{
						let select = document.getElementById( 'groupMembers');

						list.forEach( (row) =>
							{
								let name = row.memberName;
								let id = row.id;
								let isGroup = (row.isGroup == 1);
								
								//
								//  Is this member a group?
								//
								if ( !isGroup)
								{
									if ( contactList.has( id))
									{
										contactList.set( id, contactList.get(id) + adjustByAmount);

										if ( contactList.get( id) <= 0)
										{
											contactList.delete( id);
										}
										document.querySelector( `.individuals option[value="${id}"]`).selected = contactList.has( id);
									}
									else
									{
										if ( adjustByAmount > 0)
										{
											contactList.set( id, 1);
											document.querySelector( `.individuals option[value="${id}"]`).selected = true;
										}
									}

								}
								else
								{
									//
									//  If this member is itself a group, process those member names as well...
									//
									updateContactList( name, adjustByAmount);
								}
							});

					});
		
				resolve();
			}
		);
}

//
//  Set the modified event handler for the member list once the page has loaded
//
window.addEventListener( "load", function ()
	{
		refreshGroupList();
		refreshContactsList();
	});

</script>

<body>
	<div id="navbar">
	</div>

<h1>Send Message</h1>

<p id="instructions">
	From the boxes on the left, select one or more individuals or groups that the message should be sent to.
	Then, in the boxes on the right, enter the message to be sent.  Note that the "<b>From</b>" and "<b>Subject</b>" entries
	will only appear in emails that are sent.  Text messages will include only the message.  When you are finished,
	press the "<b>Send</b>" button.
</p>

<div class="messageScreen">
	<div class="groupCol showCheckBoxes">
		<div>
			<label for="groups">Groups:</label>
			<p/>
			<select name="groups" class="groups" id="groups" size="11" multiple> 
				<option value="Choir" class="multiSel" type="group">Choir</option>
				<option value="SPR" class="multiSel" type="group">SPR</option>
				<option value="Staff" class="multiSel" type="group">Staff</option>
				<option value="Trustees" class="multiSel" type="group">Trustees</option>
			</select>
			<p/>
		</div>
	</div>
	<form name="sendMessage" action="<%=url_for('sendMessage')->to_abs%>" method="post" class="messageForm">
		<div class="indivCol showCheckBoxes">
			<div>
				<label for="individuals">Individuals:</label>
				<p/>
				<select name="individuals" class="individuals" id="individuals" size="11" multiple>
					<option value="Bob 41" class="multiSel" type="member">Bob</option>
					<option value="Gus 41" class="multiSel" type="member">Gus</option>
					<option value="Sam 41" class="multiSel" type="member">Sam</option>
					<option value="Joe 41" class="multiSel" type="member">Joe</option>
					<option value="Will 41" class="multiSel" type="member">William A. Stanley</option>
				</select>
				<p/>
				<div>
					<button type="button" onClick="selectAllContacts()">Select All</button>
					<button type="button" onClick="clearContacts()">Select None</button>
				</div>
			</div>
		</div>
		<div class="messageCol">
			<div class="messageWindow">
				<div class="label1">
					<label for="from">From:</label>
				</div>
				<div class="from">
					<input type="text" name="from" id="name" placeholder="From (for email)">
				</div>
				<div class="label2">
					<label for="subject">Subject:</label>
				</div>
				<div class="subject">
					<input type="text" name="subject" id="subject" placeholder="Subject (for email)">
				</div>
				<div class="label3">
					<label for="theMessage">Message:</label>
				</div>
				<div class="messageText">
					<textarea name="theMessage" id="messageText" placeholder="Message to send"></textarea>
				</div>
				<div class="sendButton">
					<input type="submit" value="Send Message"></input>
				</div>
			</div>
		</div>
	</form>
</div>

</body>
</html>

