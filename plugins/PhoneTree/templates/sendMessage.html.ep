<html>

<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <link rel="stylesheet" href="/phonetree/site.css">
</head>

<script src="/common/Dialog.js"></script>
<script src="/common/loadNav.js"></script>
<script src="/common/PhoneTree.js"></script>

<script>

//==============================================================================
//  function refreshGroupList()
//==============================================================================
function refreshGroupList()
{
	redrawGroupList( "groups", () => {multiSelectWithoutCtrl( 'multiSel');});
}

//==============================================================================
//  function refreshContactsList()
//  	This function refreshes the list of contact names.
//==============================================================================
function refreshContactsList()
{
	let select = document.getElementById( 'individuals');

	//
	//  First clear the list
	//
	while( select.options.length > 0)
	{
		select.remove(0);
	}

	readContactList()
		.then(( list) =>
			{
				let select = document.getElementById( 'individuals');

				list.forEach( (row) =>
					{
						let option = new Option( row.firstname + " " + row.lastname, row.rowid);
						option.className = "multiSel";
						option.setAttribute( "type", "member");
						select.add( option);
					});

				multiSelectWithoutCtrl('multiSel');
			});

}

//
//  Set the modified event handler for the member list once the page has loaded
//
window.addEventListener( "load", function ()
	{
		refreshGroupList();
		refreshContactsList();
	});

</script>

<body>
	<div id="navbar">
	</div>

<h1>Send Message</h1>

<p id="instructions">
	From the boxes on the left, select one or more individuals or groups that the message should be sent to.
	Then, in the boxes on the right, enter the message to be sent.  Note that the "<b>From</b>" and "<b>Subject</b>" entries
	will only appear in emails that are sent.  Text messages will include only the message.  When you are finished,
	press the "<b>Send</b>" button.
</p>

<div class="messageScreen">
	<div class="groupCol showCheckBoxes">
		<div>
			<label for="groups">Groups:</label>
			<p/>
			<select name="groups" class="groups" id="groups" size="11" multiple>
				<option value="Choir" class="multiSel" type="group">Choir</option>
				<option value="SPR" class="multiSel" type="group">SPR</option>
				<option value="Staff" class="multiSel" type="group">Staff</option>
				<option value="Trustees" class="multiSel" type="group">Trustees</option>
			</select>
			<p/>
			<div>
				<button onClick="selectAllItems( 'groups')">Select All</button>
				<button onClick="unSelectAllItems( 'groups')">Select None</button>
			</div>
		</div>
	</div>
	<div class="indivCol showCheckBoxes">
		<div>
			<label for="individuals">Individuals:</label>
			<p/>
			<select name="individuals" class="individuals" id="individuals" size="11" multiple>
				<option value="Bob 41" class="multiSel" type="member">Bob</option>
				<option value="Gus 41" class="multiSel" type="member">Gus</option>
				<option value="Sam 41" class="multiSel" type="member">Sam</option>
				<option value="Joe 41" class="multiSel" type="member">Joe</option>
				<option value="Will 41" class="multiSel" type="member">William A. Stanley</option>
			</select>
			<p/>
			<div>
				<button onClick="selectAllItems( 'individuals')">Select All</button>
				<button onClick="unSelectAllItems( 'individuals')">Select None</button>
			</div>
		</div>
	</div>
	<div class="messageCol">
		<div class="messageWindow">
			<div class="label1">
				<label for="from">From:</label>
			</div>
			<div class="from">
				<input type="text" name="from" id="name" placeholder="From (for email)">
			</div>
			<div class="label2">
				<label for="subject">Subject:</label>
			</div>
			<div class="subject">
				<input type="text" name="subject" id="subject" placeholder="Subject (for email)">
			</div>
			<div class="label3">
				<label for="theMessage">Message:</label>
			</div>
			<div class="messageText">
				<textarea name="theMessage" id="messageText" placeholder="Message to send"></textarea>
			</div>
			<div class="sendButton">
				<button onClick="sendMessage()">Send Message</button>
			</div>
		</div>
	</div>
</div>

</body>
</html>

