	#------------------------------------------------------------------------------
	#  post '/setPasssword' -- This screen processes a reset password request
	#------------------------------------------------------------------------------
	post '/setPassword' => sub
	{
		my $self = shift;
		my $password = $self->param( 'password');
		my $password2 = $self->param( 'password2');

print "Got password reset request for " .$self->session('user') . "\n";

		if ( defined( $self->session( 'user')) && defined( $self->session( 'UID')))
		{
			##
			##  See if this userId/password is defined
			##
			my $memberInfo = getUserInfo( $self->session( 'user'), $self->session( 'UID'));

			if ( defined( $memberInfo))
			{
				##
				##  Verify that the provided passwords match
				##
				if ( $password eq $password2)
				{
					$memberInfo->{loginId} = $self->session('user');
					$memberInfo->{password} = $password;

					print "USER=" . $self->session->{user} . "\n";
					print "Deleting...\n";
					delete $self->session->{'user'};

					print "\n\nWriting:\n\t" . Dumper( $memberInfo) . "\n\n";
					writeMemberInfo( $memberInfo);
					$self->redirect_to( '/');
				}
				else
				{
					$self->stash( loginId => $self->session->{user});
					$self->flash( error=> "Passwords don't match! Please try again.");
##-->					$self->render( 'setPassword');
					$self->redirect_to( 'setPassword');
				}
			}
			else
			{
				print "Got bad password reset request!!!\n";
				$self->render( 'not_found');
			}
		}
		else
		{
			print "Got bad password reset request!!!\n";
			$self->render( 'not_found');
		}
	};


	#------------------------------------------------------------------------------
	#  EVERY page below here first gets authenticated by this routine
	#------------------------------------------------------------------------------
	under sub
	{
##-->		print "\n\nIn top under, Checking for login...\n";
		my $self = shift;
		
		##
		##  Is this a user updating their password via the provided link?
		## 
		if ( defined( $self->param("user")) && defined( $self->param( "UID")))
		{
##-->			print "Looking for user" .  $self->param("user") . " with ID ". $self->param( "UID") . "\n";
			##
			##  Does the user ID for the named user match the provided ID?
			##
			my $info = getUserInfo( $self->param("user"), $self->param( "UID"));

			##
			##  Does the username and UID match with a user?
			##
			if ( defined( $info))
			{
##-->		print "Found info\n";
				##
				##  Is the password defined?
				##
				if ( defined( $info->{password}) && length( $info->{password}))
				{
##-->		print "password defined\n";
					##
					##  If we are here, either the user is reusing
					##  their "signup" link or someone is trying to
					##  sneak in.  Remember the page asked for and
					##  redirect to login.
					##
					$self->session->{lastCall} = $self->{tx}->{req}->{url}->{path}->{path};
					$self->redirect_to( 'login');
				}
				else
				{
					##
					##  If we are here, then we need to get the password for a new user.
					##
##-->					print "\n\n\n ******** Get New User Password for " . $self->param('user') . "!!!!! *************\n\n\n";
					$self->session( 'UID' => $self->param('UID'),
									'user' => $self->param( 'user'),
									expiration =>500);
					$self->redirect_to( 'setPassword');
				}
##-->		print "Returning 1\n";
				return 1;
			}

##-->        print "why here?\n";

			$self->render(  'not_found');
			return;
		}

		##
		##	Is the user already logged in?
		##
		print "Checking for a cookie\n";
		if ( defined( $self->cookie( 'UID')))
		{
			if ( UIDExists( $self->cookie('UID')))
			{
				print "User is already logged in...\n";
				return 1;
			}
			else
			{
				print "Invalid cookie\n";
			}
		}

		print "Redirecting to login...\n";
		
		##
		##  redirect to login.
		##
		$self->session->{lastCall} = $self->{tx}->{req}->{url}->{path}->{path};
		$self->redirect_to( 'login');
		return 0;
	};

