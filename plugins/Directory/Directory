		#------------------------------------------------------------------------------
		#  post '/addNewMember'
		#------------------------------------------------------------------------------
		post '/addNewMember' => sub
		{
			my $self = shift;

			my $json = $self->req->json();

			my $name = $json->{firstName} . $json->{lastName};
			my $count = 1;
			my $id = "${name}_${count}";
			$id =~ s/\s//g;
			$id =~ s/\p{Punct}//g;

			$json->{loginId} = $id;
			$json->{UID} = generateUID();
			
			readMembers();

			while( defined( $members->{$id}))
			{
				$count++;
				$id = "${name}_${count}";
			}

			$json->{loginId} = $id;
			$members->{$id} = $json;
			writeMemberInfo( $json);

			my %config = getConfigInfo();

			if ( $config{DirectoryAutoWelcome})
			{
				sendNoticeToMember( $json, "New");
			}
		 
			$self->render( json => {status=> 'Saved'});
		};

