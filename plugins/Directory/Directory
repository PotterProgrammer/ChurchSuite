	#------------------------------------------------------------------------------
	#  post '/uploadMyPhoto'
	#------------------------------------------------------------------------------
	post '/uploadMyPhoto' => sub
	{
		my $self = shift;
	 
		# Check file size
		if ($self->req->is_limit_exceeded)
		{
			return $self->render(text => 'File is too big.', status => 200);
		}
	 
		# Process uploaded file
		my $imageFile = $self->param('imageFile');
		my $size = $imageFile->size;
		my $name = $imageFile->filename;
		$name =~ s/\s//g;
		$name =~ s/[:\[\]\(\)\!\,\;]//g;
		
		open( my $PHOTO, '>', "public/directory/Photos/photo-$name") || die "Can't make the file 'public/directory/Photos/photo-$name! $!\n";
		my $data = $imageFile->asset->slurp;
		binmode( $PHOTO);
		syswrite( $PHOTO, $data);
		close $PHOTO;
		my $reply = { photo => "/directory/Photos/photo-$name"};

		$self->render( json => $reply);
	};

	#------------------------------------------------------------------------------
	#  websocket '/getPersonalInfo
	#  		This call provides the personal information for the given person.
	#------------------------------------------------------------------------------
	websocket '/getPersonalInfo' => sub
	{
		my $self = shift;
		readMembers();

		##
		##  See if we received a message
		##
		$self->on( json => sub
				{
					my ($self, $json) = @_;

					my $name = $json->{tag};

					if ( !defined( $json->{formatted}) || $json->{formatted})
					{
						my $html = '<img id="copyIcon" src="/directory/copy.png" onclick="copyInfo()" title="Copy"><div class="infoBox"><fullName>' . 
								    $members->{$name}->{firstName} . ' ' . $members->{$name}->{lastName} . "</fullName>\n";

						if ( defined( $members->{$name}->{children}) && length( $members->{$name}->{children}))
						{
							$html .= 'Children: <children>' . $members->{$name}->{children} . '</children><br><br>';
						}

						if ( defined( $members->{$name}->{address}) && length( $members->{$name}->{address}))
						{
							$html .= '<street>' . $members->{$name}->{address} . "</street>\n";
						}
						my $separator = '';
						if ( defined( $members->{$name}->{city}) && length( $members->{$name}->{city}))
						{
							if ( defined( $members->{$name}->{zip}) && length( $members->{$name}->{zip}))
							{
								$separator = ', '
							}
							$html .= '<city>' . $members->{$name}->{city} . $separator . "</city>\n";
						}
						if ( defined( $members->{$name}->{zip}) && length( $members->{$name}->{zip}))
						{
							$html .= '<zip>' . $members->{$name}->{zip} . "</zip>\n";
						}
						if (( defined( $members->{$name}->{phone}) && length( $members->{$name}->{phone})) ||
							( defined( $members->{$name}->{cell}) && length( $members->{$name}->{cell})))
						{
							$html .= "<phoneBlock>";
							
							if ( defined( $members->{$name}->{phone}) && length( $members->{$name}->{phone}))
							{
								$html .= '<phone>phone:</phone> <phoneNumber><a href="tel:' . $members->{$name}->{phone}. '">' . $members->{$name}->{phone} . "</a></phoneNumber>\n";
							}
							if ( defined( $members->{$name}->{cell}) && length( $members->{$name}->{cell}))
							{
								$html .= '<cell>cell:</cell> <phoneNumber><a href="tel:' .$members->{$name}->{cell}.'">' . $members->{$name}->{cell} . "</a></phoneNumber>\n";
							}
							if ( defined( $members->{$name}->{cell2}) && length( $members->{$name}->{cell2}))
							{
								$html .= '<cell>cell:</cell> <phoneNumber><a href="tel:' .$members->{$name}->{cell2}.'">' . $members->{$name}->{cell2} . "</a></phoneNumber>\n";
							}
							$html .= "</phoneBlock>\n";
						}
						if ( defined( $members->{$name}->{email}) && length( $members->{$name}->{email}))
						{
							$html .= '<email><a href="mailto:' .$members->{$name}->{email}.'">'.  $members->{$name}->{email} . "</a></email>\n";
						}
						if ( defined( $members->{$name}->{email2}) && length( $members->{$name}->{email2}))
						{
							$html .= '<email><a href="mailto:' .$members->{$name}->{email2}.'">'.  $members->{$name}->{email2} . "</a></email>\n";
						}
						$html .= '<br></div>';

						##
						##  Send back info
						##
						$self->send( $html);
					}
					else
					{
						##
						##  Send back the json
						##
						$self->send({ json => $members->{$name}});
					}
				}
		 );
		
	};


