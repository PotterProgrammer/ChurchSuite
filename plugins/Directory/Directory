			my $autoWelcome = $self->param('autoWelcome');

			my %config = ( DirectoryAutoWelcome => (defined( $autoWelcome) && ( $autoWelcome eq 'on')) ? 1 : 0);
			print "\n\n Got back " . $config{DirectoryAutoWelcome} . "\n";

			saveConfig( %config);

			$self->render( 'admin');
		};
		
		
		#------------------------------------------------------------------------------
		#	post '/restore'
		#		This call carries out the actual restore
		#------------------------------------------------------------------------------
		post '/restore' => sub
		{
			my $self = shift;
		 
			# Check file size
			if ($self->req->is_limit_exceeded)
			{
				return $self->render(text => 'File is too big.', status => 200);
			}
		 
			# Process uploaded file
			my $filename = $self->param('filename');

			my %response = restoreBackup( $filename, $backupPassphrase);

			print "Got back " . Dumper( %response) . "\n";
			$self->stash( textMessage => $response{textMessage}, backupFile=> $response{backupFile}, title=> $response{title}, showFor => $response{showFor});
			
			if ( !defined( $response{backupFile}))
			{
				print "Rendering index...\n";
				$self->render( 'admin');
			}
			else
			{
				$self->render( 'restoreBackup');
			}
		};
		
		#------------------------------------------------------------------------------
		#  post '/restoreCommon'
		#  		This call restores the common config settings from the provided
		#  		temporary backup filename.
		#------------------------------------------------------------------------------
		post '/restoreCommon' => sub
		{
			my $self = shift;

			my $json = $self->req->json();
			my $backupName = $json->{backupName};
			
			restoreCommonSettings( $backupName, $backupPassphrase);
			$self->render( 'admin');
		};
		
		#------------------------------------------------------------------------------
		#  post '/releaseBackupData'
		#  		This call releases the temporarily stored common configuration settings
		#  		backup file created during the restore.
		#------------------------------------------------------------------------------
		post '/releaseBackupData' => sub
		{
			my $self = shift;

			my $json = $self->req->json();
			my $backupName = $json->{backupName};
			
			releaseBackupData( $backupName);
			$self->render( 'admin');
		};
		
		
		#------------------------------------------------------------------------------
		#  post '/resetPassword'
		#------------------------------------------------------------------------------
		post '/resetPassword' => sub
		{
			my $self = shift;

			##
			##  Get the JSON
			##
			my $json = $self->req->json();

			##
			##  Get the member ID
			##
			my $id = $json->{loginId};


			##
			##  Reset the password
			##
			resetMemberPassword( $id);

			##
			##  Get the user info
			##
			my $memberInfo = lookupUser( $id, "");

			##
			##  Send the user an email or SMS
			##
			sendNoticeToMember( $memberInfo, "Reset");

			$self->render( json => {status=> 'Password reset'});
		};

		#------------------------------------------------------------------------------
		#  post '/toggleAdmin'
		#------------------------------------------------------------------------------
		post '/toggleAdmin' => sub
		{
			my $self = shift;

			##
			##  Get the JSON
			##
			my $json = $self->req->json();

			##
			##  Get the member ID
			##
			my $id = $json->{loginId};


			##
			##  Toggle the admin setting
			##
			toggleAdmin( $id);

			$self->render( json => {status=> 'Status changed'});
		};

		#------------------------------------------------------------------------------
		#	websocket '/backup'
		#		This call stores the existing config and database in a tar file,
		#		encrypts it, and then makes it available for download.
		#------------------------------------------------------------------------------
		websocket '/backup' => sub
		{
			my $ws = shift;

			$ws->on (text => sub
				{
					$ws->inactivity_timeout(300);
					my ($ws, $message) = @_;

					print "Got a '$message' request\n";
					if ( $message =~ m/Backup/)
					{
						my $backupFilename = backupData( $backupPassphrase);
						$ws->send( $backupFilename);
					}
					else
					{
						$ws->send( "What??!");
					}
				}
				);
		};
	};

	
	app->config( hypnotoad=>{listen =>['http://*:3000']});
	app->secrets( ['Your mileage may vary']);
	return app->start;
}

#------------------------------------------------------------------------------
#  sub updateMemberInfo( @)
#  		Update information about one member
#------------------------------------------------------------------------------
sub updateMemberInfo()
{
	my $self = shift;

	##
	##  Get the JSON
	##
	my $json = $self->req->json();

	##
	##  Get the member ID
	##
	my $id = $json->{loginId};

	print "Modifying entry for user $id\n";
	readMembers();

	foreach my $key (keys(%{$json}))
	{
		print "Changing $key from $members->{$id}->{$key} to $json->{$key}\n";
		$members->{$id}->{$key} = $json->{$key};
	}

	writeMemberInfo( $members->{$id});
}

#------------------------------------------------------------------------------
#  sub readMembers()
#  		Reads the member info list from disk
#------------------------------------------------------------------------------
sub readMembers()
{
	$members = readDirectoryMembers();
}

#------------------------------------------------------------------------------
#  sub saveMembers()
#  		Writes the member list to disk in JSON format
#------------------------------------------------------------------------------
sub saveMembers()
{
	saveDirectoryMembers( $members);
}
