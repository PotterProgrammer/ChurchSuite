<!DOCTYPE html>

<html>

<head>
	<script src="/common/Dialog.js"> </script>
	<link rel="stylesheet" href="/directory/site.css">
	<script src="/common/loadNav.js"> </script>
</head>

<script>

//------------------------------------------------------------------------------
//  function pickedAName()
//------------------------------------------------------------------------------
function pickedAName()
{
    let list = document.getElementById( 'memberNames');
    let selectedIndex = list.selectedIndex;
    let item = list.options[selectedIndex];
    let id = item.value;
	let text = item.text;
	let button = document.getElementById( 'toggleStatus');


	if ( text.startsWith( '☐'))
	{
		button.innerText = 'Make Administrator';
		button.value = true;
	}
	else
	{
		button.innerText = 'Do NOT Make Administrator';
		button.value = false;
	}
	button.disabled = false;
}


//------------------------------------------------------------------------------
//  function toggleAdmin()
//------------------------------------------------------------------------------
function toggleAdmin()
{
    let list = document.getElementById( 'memberNames');
    let selectedIndex = list.selectedIndex;
	if ( selectedIndex < 0)
	{
		Dialog.Alert( {title: "Error", text: "You must first select a member name from the list"});
		return;
	}

    let item = list.options[selectedIndex];
    let id = item.value;
    
    //
    //  Add the selected ID to the reset request
    //
    const fetchOptions = {
                            method: "POST",
							body:  '{ "loginId": "' + id + '"}'
                         };

    let url =  "/directory/toggleAdmin";

    fetch( url, fetchOptions)
        .then( response => response.json())
        .then( data => {
               Dialog.Notify( { title: data.status,  text: "", showFor: 1000 }).then( ()=>
               {
                   window.location.reload();
               });
             });

}
</script>


<body>
  <div id="navbar">
  </div>
  
  <TheTitle>Edit Directory Admins</TheTitle>
  
  <div id="page">
    <adminNamesList>
      <select id="memberNames" size="23" onchange="pickedAName()" >
        %my @sortedNames = sort { $members->{$a}->{lastName}. $members->{$a}->{firstName} cmp $members->{$b}->{lastName} . $members->{$b}->{firstName}} keys( %{$members});
        %foreach my $id ( @sortedNames)
        %{
		%##  my $ballotBox = ( defined($members->{$id}->{admin}) && ($members->{$id}->{admin})) ? "🗹" : "☐";
		%  my $ballotBox = ( defined($members->{$id}->{admin}) && ($members->{$id}->{admin})) ? "☑" : "☐";
          <option value="<%= $id %>"><%=  "$ballotBox    " .$members->{$id}->{firstName}%> <%=$members->{$id}->{lastName} %></option>
        %}
      </select>
    </adminNamesList>
    <div id="instructions">
		<p>Members who are authorized to adminster the directory have a check mark beside their name.  To change the status of a member, select the member's 
		name from the list and click the button below.
		<div class="buttonrow">
			<button id="toggleStatus" onclick="toggleAdmin()" disabled>Make Administrator</button>
		</div>
	</div>
  </div>
</body>
</html>

