<!DOCTYPE html>

<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
	<link rel="stylesheet" href="/scheduler/site.css">
</head>

<style>

instruction
{
	text-align: center;
	font-weight: 600;
	font-size: 18pt;
	display:block;
	margin-top: 2.5em;
}

green
{
	color: #00ff00;
}

form .pwdForm
{
    display:grid;
    grid-template-columns: max-content max-content;
    grid-gap: 5px;
	width:30%;
	margin-left: auto;
	margin-right:auto;
	margin-top:3%;
	margin-bottom: 2em;
}


form .pwdForm input
{
	height: 1.2em;
	margin-bottom: 1.2em;
}

.infoLabel
{
	text-align: right;
}

.allCentered
{
	text-align: center;
}

.error
{
	color: red;
	margin-top: 1em;
}

</style>

<body>
	<div id="xoverlay">

		<h1>Directory</h1>
			<div class="allCentered">
				<instruction>Set new password for <green><%= $loginId %></green>:</instruction>
			<form method="post" action='/directory/setPassword'>
				<div  class="pwdForm">
					<label for="user" class="infoLabel">New Password:</label>
					<input class="form-control" id="password" name="password" type="password" size="40" autofocus/>
					<label for="password" class="infoLabel">Re-type Password:</label>
					<input class="form-control" id="password" name="password2" type="password" size="40" />
				</div>
					<input class="btn btn-primary" type="submit" value="Save Password">
			</form>

			% if (defined( flash 'error') ) {
				<div class="error" style="color: red">
					<center><b> <%= flash 'error' %> </b></center>
				</div>
			%}
		</div>

	</div>
</body>
</html>

