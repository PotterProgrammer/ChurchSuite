<!DOCTYPE html>

<html>

<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
	<script src="/common/Dialog.js"> </script>
	<link rel="stylesheet" href="/directory/site.css">
</head>

<script src="/common/loadNav.js"> </script>

<script>
//------------------------------------------------------------------------------
//  function pickedAName()
//		Toggle on the reset button once a name is selected
//------------------------------------------------------------------------------
function pickedAName()
{
	let button = document.getElementById( "resetButton");
	button.disabled = false;
}

//------------------------------------------------------------------------------
//  function resetAPassword()
//------------------------------------------------------------------------------
function resetAPassword()
{
    let list = document.getElementById( 'memberNames');
    let selectedIndex = list.selectedIndex;
	if ( selectedIndex < 0)
	{
		Dialog.Alert( {title: "Error", text: "You must first select a member name from the list"});
		return;
	}

    let item = list.options[selectedIndex];
    let id = item.value;
	let obj;
    
    
    //
    //  Add the selected ID to the reset request
    //
    const fetchOptions = {
                            method: "POST",
							body:  '{ "loginId": "' + id + '"}'
                         };

    let url =  "/directory/resetPassword";

    fetch( url, fetchOptions)
        .then( response => response.json())
        .then( data => {
               Dialog.Notify( { title: data.status,  text: "", showFor: 1500 }).then( ()=>
               {
                   window.location.reload();
               });
             });

}
</script>


<body>
  <div id="navbar">
  </div>
  
  
  <TheTitle>Reset Member Password</TheTitle>
  
  <div id="page">
    <namesList>
      <select id="memberNames" size="23" onchange="pickedAName()" >
        %my @sortedNames = sort { $members->{$a}->{lastName}. $members->{$a}->{firstName} cmp $members->{$b}->{lastName} . $members->{$b}->{firstName}} keys( %{$members});
        %foreach my $id ( @sortedNames)
        %{
          <option value="<%= $id %>"><%= $members->{$id}->{firstName}%> <%=$members->{$id}->{lastName} %></option>
        %}
      </select>
    </namesList>
    <div id="instructions">
		<p>Select the name of the member whose password needs to be reset and then push the "Reset Passord" button below to reset the password.</p>
		<button id="resetButton" onclick="resetAPassword();" disabled>Reset Password</button>
	</div>
  </div>
</body>
</html>
