<!DOCTYPE html>

<html>
<head>
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
	<link rel="stylesheet" href="/scheduler/site.css">
</head>

<body>
	<div id="xoverlay">

		<h1>Scheduler</h1>
		<div  class="loginForm">
			<form method="post" action='/scheduler/login'>
				<label for="user">Login Name:</label>
				<input class="form-control" id="user" name="user" type="text" size="40" autofocus/>
				<br/> 
				<label for="password" style="margin-right:1em">Password:</label>
				<input class="form-control" id="password" name="password" type="password" size="40" />
				<br/> 
				<input class="btn btn-primary" type="submit" value="Sign In">
				<br/>  <br/>
			</form>

			% if (defined( flash 'error') ) {
				<div class="error" style="color: red">
					<center><b> <%= flash 'error' %> </b></center>
				</div>
			%}
		</div>

	</div>
</body>
</html>

