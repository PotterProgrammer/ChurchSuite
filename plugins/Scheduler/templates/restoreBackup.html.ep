<!DOCTYPE html>

<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
	<link rel="stylesheet" href="/scheduler/site.css">
</head>

<script src="/scheduler/scheduler.js"> </script>
<script src="/common/Dialog.js"></script>

<script>

	function verifyConfigOverwrite()
	{
		let message = 'The backup file contains configuration settings for email or texting that are different than the current settings.<br>Do you wish to use the settings from the backup file?'

		Dialog.Confirm( {text: message, title: "Caution:"}).then( (answer) =>
			{
				if ( answer)
				{
					fetch( '/scheduler/restoreCommon',
							{
								method: "POST",
								body: JSON.stringify( { 'backupName': '<%= $backupFile %>'}),
								headers: { "Content-type": "application/json"}
							}
						  )
					.then( response => 
							{
								window.location.href = 'index';
							});
				}
				else
				{
					fetch( '/scheduler/releaseBackupData',
							{
								method: "POST",
								body: JSON.stringify( { 'backupName': '<%= $backupFile %>'}),
								headers: { "Content-type": "application/json"}
							}
						  )
					.then( response => 
							{
								window.location.href = 'index';
							});
				}
			});
	}


% if ( defined( stash( 'backupFile')))
% {	
	window.addEventListener( "pageshow", function () {verifyConfigOverwrite();} );
% }

</script>

<body>
	<div id="navbar">
	</div>

	<h1>Restore from Backup</h1>

	<div id="viewSchedule">
		<p>This process will restore the scheduling environment (including volunteers, positions, schedules and settings) to the state that it was in when the backup file was created.</p>
		<p>Note that this will erase <b><u>all</u></b> currently entered information, including schedules, replacing it with the contents of the backup file!</p>
		<p>Are you sure you wish to continue?</p>
		<br>
		<button onclick="document.getElementById('filename').click();">Yes</button>
		<button onclick="window.location='/scheduler/'">No</button>
		<form action = "/scheduler/restore" method="post" enctype="multipart/form-data" hidden>
			<input id="filename" type="file" name="filename" onchange="document.getElementById('sendBackup').click();" hidden/>
			<button id="sendBackup" type="submit" hidden/>
		</form>
	</div>
</body>

</html>
